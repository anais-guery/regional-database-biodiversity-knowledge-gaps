INCLUDE TCL
   if {{OUTGOING} == {OUTGOING}} {      set attrs [list {knowledgescore}];    } else {      set attrAll {<Unused>};      if {[string length $attrAll] == 0} { return; };      set attrs [split {<Unused>} { }];    };    if {{NO_OP} == {NO_OP}} {        set parmList ATTR_CREATE_EXPR_PROPAGATE_MISSING_TYPED_FDIV;    } else {        set parmList ATTR_CREATE_EXPR_PROPAGATE_MISSING_TYPED_FDIV_MULTI_FEATURE;    };    foreach attr $attrs {     lappend parmList $attr;     lappend parmList {1-<at>Value<openparen>ignoranceindex<closeparen>};     lappend parmList {FLOAT};    };    lappend parmList {knowledge_score};    if {{NO_OP} == {OTHER_NULL_VALUE_2}} {     lappend parmList {NO_OP};     lappend parmList {<Unused>};     lappend parmList {0};    };    puts "MACRO __fme_expressionevaluator_evaluateArgs__ [join $parmList ,]";
END_INCLUDE
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { knowledge_score }    INPUT  FEATURE_TYPE join_completeness_ignorance_JOINED    OUTPUT { FEATURE_TYPE knowledge_score_OUTPUT         @EvaluateExpression($(__fme_expressionevaluator_evaluateArgs__))          }
MACRO __fme_expressionevaluator_evaluateArgs__
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split ""] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO remove_unused_attributes_LIST_FUNC }    } else {        puts "MACRO remove_unused_attributes_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { remove_unused_attributes }    INPUT  FEATURE_TYPE knowledge_score_OUTPUT    OUTPUT { FEATURE_TYPE remove_unused_attributes_OUTPUT        @RemoveAttributes(fme_encoded,PERCENTAGE,Pourcentage,Shape_Area,Shape_Leng,f1,f2,Ni,total_count,chao1_estimate,espececount,AREA,maille10_1)        $(remove_unused_attributes_LIST_FUNC)         }
